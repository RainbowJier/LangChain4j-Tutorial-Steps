<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="混合检索 + Rerank 流程" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="170" y="15" width="280" height="30" as="geometry"/>
    </mxCell>
    <!-- Query -->
    <mxCell id="query" value="用户查询：&#xa;&quot;国土空间规划法第八条&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="220" y="55" width="180" height="40" as="geometry"/>
    </mxCell>
    <!-- Branch arrows -->
    <mxCell id="branch1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="query" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="120" y="140" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="120" y="95"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="branch2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;" edge="1" source="query" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="500" y="140" as="targetPoint"/>
        <Array as="points">
          <mxPoint x="500" y="95"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <!-- Semantic Search -->
    <mxCell id="sem" value="语义检索&#xa;(向量相似度)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="40" y="140" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="semResult" value="结果A：20条&#xa;(语义相关)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="50" y="210" width="140" height="35" as="geometry"/>
    </mxCell>
    <!-- Keyword Search -->
    <mxCell id="kw" value="关键词检索&#xa;(BM25 算法)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="420" y="140" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="kwResult" value="结果B：20条&#xa;(关键词匹配)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="430" y="210" width="140" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="eSem" style="rounded=1;" edge="1" source="sem" target="semResult" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="eKw" style="rounded=1;" edge="1" source="kw" target="kwResult" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Merge -->
    <mxCell id="merge" value="合并 + 去重&#xa;~30 条候选" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="230" y="280" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="eMerge1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="semResult" target="merge" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="eMerge2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="kwResult" target="merge" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Rerank -->
    <mxCell id="rerank" value="Rerank 重排序&#xa;(Cross-Encoder 精排)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="230" y="360" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="eRerank" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="merge" target="rerank" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Final -->
    <mxCell id="final" value="最终 Top-5&#xa;高质量结果" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="230" y="440" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="eFinal" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="rerank" target="final" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Time annotations -->
    <mxCell id="t1" value="~20ms" style="text;fontSize=9;fontColor=#82b366;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="170" y="145" width="50" height="15" as="geometry"/>
    </mxCell>
    <mxCell id="t2" value="~20ms" style="text;fontSize=9;fontColor=#6c8ebf;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="530" y="145" width="50" height="15" as="geometry"/>
    </mxCell>
    <mxCell id="t3" value="~2.5s" style="text;fontSize=9;fontColor=#9673a6;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="395" y="365" width="50" height="15" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
