<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="RAG vs 纯 LLM 对比" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="200" y="20" width="300" height="30" as="geometry"/>
    </mxCell>
    <!-- Column Headers -->
    <mxCell id="h1" value="纯 LLM（闭卷）" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="40" y="70" width="200" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="h2" value="LLM + RAG（开卷）" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="420" y="70" width="200" height="40" as="geometry"/>
    </mxCell>
    <!-- Pure LLM Flow -->
    <mxCell id="n1" value="用户提问" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="80" y="140" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="n2" value="LLM&#xa;凭记忆回答" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="80" y="230" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="n3" value="可能幻觉 ❌&#xa;编造法规条文" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="60" y="320" width="160" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="n1" target="n2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="n2" target="n3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- RAG Flow -->
    <mxCell id="r1" value="用户提问" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="460" y="140" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="r2" value="① 检索&#xa;从文档库找资料" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="460" y="230" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="r3" value="② 增强&#xa;拼接 Prompt" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="460" y="320" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="r4" value="③ LLM 生成&#xa;基于资料回答" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="460" y="410" width="120" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="r5" value="可溯源 ✅&#xa;引用真实文件" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#2d7600;" vertex="1" parent="1">
      <mxGeometry x="440" y="500" width="160" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="re1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="r1" target="r2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="re2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="r2" target="r3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="re3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="r3" target="r4" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="re4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="r4" target="r5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Doc Store -->
    <mxCell id="docs" value="文档库&#xa;(向量数据库)" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="630" y="215" width="100" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="de1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;strokeColor=#9673a6;" edge="1" source="r2" target="docs" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- VS -->
    <mxCell id="vs" value="VS" style="text;fontSize=20;fontStyle=1;fontColor=#666666;align=center;" vertex="1" parent="1">
      <mxGeometry x="295" y="230" width="50" height="30" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
