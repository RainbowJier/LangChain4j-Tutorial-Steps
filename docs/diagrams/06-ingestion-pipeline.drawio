<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="文档摄入管道" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="220" y="15" width="220" height="30" as="geometry"/>
    </mxCell>
    <!-- Stage 1: Load -->
    <mxCell id="s1" value="① 加载" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="100" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="s1d" value="FileSystemDocument&#xa;Loader.loadDocument()&#xa;从磁盘读取文件" style="text;fontSize=9;fontColor=#6c8ebf;align=center;" vertex="1" parent="1">
      <mxGeometry x="20" y="105" width="140" height="40" as="geometry"/>
    </mxCell>
    <!-- Stage 2: Parse -->
    <mxCell id="s2" value="② 解析" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="160" y="60" width="100" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="s2d" value="PDF → PdfBox&#xa;DOCX → POI&#xa;TXT → TextParser" style="text;fontSize=9;fontColor=#d6b656;align=center;" vertex="1" parent="1">
      <mxGeometry x="140" y="105" width="140" height="40" as="geometry"/>
    </mxCell>
    <!-- Stage 3: Preprocess -->
    <mxCell id="s3" value="③ 预处理" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="280" y="60" width="100" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="s3d" value="去空行、去页码&#xa;统一编码&#xa;表格线性化" style="text;fontSize=9;fontColor=#d6b656;align=center;" vertex="1" parent="1">
      <mxGeometry x="260" y="105" width="140" height="40" as="geometry"/>
    </mxCell>
    <!-- Stage 4: Split -->
    <mxCell id="s4" value="④ 分块" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="400" y="60" width="100" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="s4d" value="DocumentSplitters&#xa;.recursive(500, 100)&#xa;段落→句子→字符" style="text;fontSize=9;fontColor=#9673a6;align=center;" vertex="1" parent="1">
      <mxGeometry x="380" y="105" width="140" height="40" as="geometry"/>
    </mxCell>
    <!-- Stage 5: Embed + Store -->
    <mxCell id="s5" value="⑤ 向量化+存储" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="520" y="60" width="120" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="s5d" value="EmbeddingModel.embed()&#xa;→ 384维向量&#xa;→ EmbeddingStore" style="text;fontSize=9;fontColor=#82b366;align=center;" vertex="1" parent="1">
      <mxGeometry x="510" y="105" width="140" height="40" as="geometry"/>
    </mxCell>
    <!-- Edges -->
    <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="s1" target="s2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="s2" target="s3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e34" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="s3" target="s4" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e45" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="s4" target="s5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Ingestor Box -->
    <mxCell id="ingestor" value="EmbeddingStoreIngestor 一键封装了 ②③④⑤" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;fontSize=10;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="140" y="165" width="350" height="30" as="geometry"/>
    </mxCell>
    <!-- File types -->
    <mxCell id="pdf" value="PDF" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="10" y="160" width="40" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="docx" value="DOCX" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="55" y="160" width="45" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="txt" value="TXT" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="105" y="160" width="35" height="25" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
