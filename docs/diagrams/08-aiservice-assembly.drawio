<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="AiService 装配 + SSE 流式" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="150" y="10" width="320" height="30" as="geometry"/>
    </mxCell>
    <!-- Left: Assembly -->
    <mxCell id="assem" value="AiService 装配" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="50" width="260" height="300" as="geometry"/>
    </mxCell>
    <mxCell id="sys" value="@SystemMessage&#xa;(人设/角色)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="assem">
      <mxGeometry x="80" y="35" width="110" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="chatm" value="ChatModel&#xa;(LLM 大脑)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="assem">
      <mxGeometry x="15" y="90" width="110" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="retr" value="ContentRetriever&#xa;(RAG 检索)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="assem">
      <mxGeometry x="140" y="90" width="110" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="memo" value="ChatMemory&#xa;(会话记忆)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="assem">
      <mxGeometry x="15" y="145" width="110" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="tool" value="@Tools&#xa;(Agent 工具)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="assem">
      <mxGeometry x="140" y="145" width="110" height="35" as="geometry"/>
    </mxCell>
    <!-- Build result -->
    <mxCell id="built" value="GeoSmartAssistant&#xa;(AiServices.build())" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#333333;fontSize=10;fontStyle=1;strokeWidth=2;" vertex="1" parent="assem">
      <mxGeometry x="50" y="210" width="170" height="35" as="geometry"/>
    </mxCell>
    <!-- Arrows to build -->
    <mxCell id="ab1" style="rounded=1;" edge="1" source="chatm" target="built" parent="assem">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="ab2" style="rounded=1;" edge="1" source="retr" target="built" parent="assem">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="ab3" style="rounded=1;" edge="1" source="memo" target="built" parent="assem">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="ab4" style="rounded=1;" edge="1" source="tool" target="built" parent="assem">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Prompt assembly -->
    <mxCell id="prompt" value="自动组装 Prompt：&#xa;System + 检索结果 + 历史 + 用户问题" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=2;" vertex="1" parent="assem">
      <mxGeometry x="30" y="260" width="200" height="30" as="geometry"/>
    </mxCell>
    <!-- Right: SSE Flow -->
    <mxCell id="sse" value="SSE 流式输出" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="320" y="50" width="280" height="300" as="geometry"/>
    </mxCell>
    <mxCell id="fe" value="前端&#xa;(fetch + ReadableStream)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="sse">
      <mxGeometry x="20" y="35" width="160" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="ctrl" value="ChatController&#xa;(SseEmitter)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sse">
      <mxGeometry x="20" y="95" width="160" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="ast" value="assistant.chat()&#xa;(TokenStream)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="sse">
      <mxGeometry x="20" y="155" width="160" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="llm" value="LLM API&#xa;(StreamingChatModel)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="sse">
      <mxGeometry x="20" y="215" width="160" height="35" as="geometry"/>
    </mxCell>
    <!-- SSE edges -->
    <mxCell id="se1" style="rounded=1;strokeColor=#6c8ebf;" edge="1" source="fe" target="ctrl" parent="sse">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="se1l" value="POST /api/chat" style="text;fontSize=8;fontColor=#6c8ebf;" vertex="1" parent="sse">
      <mxGeometry x="180" y="60" width="80" height="15" as="geometry"/>
    </mxCell>
    <mxCell id="se2" style="rounded=1;strokeColor=#d6b656;" edge="1" source="ctrl" target="ast" parent="sse">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="se3" style="rounded=1;strokeColor=#9673a6;" edge="1" source="ast" target="llm" parent="sse">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Token flow back -->
    <mxCell id="se4" style="rounded=1;strokeColor=#82b366;dashed=1;" edge="1" source="llm" target="ctrl" parent="sse">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="240" y="233"/>
          <mxPoint x="240" y="113"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="se4l" value="逐 token&#xa;回调" style="text;fontSize=8;fontColor=#82b366;" vertex="1" parent="sse">
      <mxGeometry x="200" y="160" width="50" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="se5" style="rounded=1;strokeColor=#82b366;dashed=1;" edge="1" source="ctrl" target="fe" parent="sse">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="230" y="113"/>
          <mxPoint x="230" y="53"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="se5l" value="data:token" style="text;fontSize=8;fontColor=#82b366;" vertex="1" parent="sse">
      <mxGeometry x="200" y="55" width="60" height="15" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
