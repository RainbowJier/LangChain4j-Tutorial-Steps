<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="生产环境部署架构" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="180" y="10" width="280" height="30" as="geometry"/>
    </mxCell>
    <!-- User -->
    <mxCell id="user" value="用户" style="shape=actor;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="280" y="50" width="30" height="40" as="geometry"/>
    </mxCell>
    <!-- Nginx -->
    <mxCell id="nginx" value="Nginx&#xa;(负载均衡)" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="240" y="110" width="110" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="eu1" style="rounded=1;" edge="1" source="user" target="nginx" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Spring Boot instances -->
    <mxCell id="app1" value="Spring Boot&#xa;实例 1" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="100" y="175" width="100" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="app2" value="Spring Boot&#xa;实例 2" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="245" y="175" width="100" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="app3" value="Spring Boot&#xa;实例 3" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="390" y="175" width="100" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="ea1" style="rounded=1;strokeColor=#666666;" edge="1" source="nginx" target="app1" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="ea2" style="rounded=1;strokeColor=#666666;" edge="1" source="nginx" target="app2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="ea3" style="rounded=1;strokeColor=#666666;" edge="1" source="nginx" target="app3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Backend Services -->
    <mxCell id="milvus" value="Milvus&#xa;(向量数据库)" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="30" y="270" width="110" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="redis" value="Redis&#xa;(会话缓存)" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="200" y="270" width="100" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="oss" value="OSS/S3&#xa;(文件存储)" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="370" y="270" width="100" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="llmapi" value="LLM API&#xa;(智谱/OpenAI)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="500" y="275" width="110" height="45" as="geometry"/>
    </mxCell>
    <!-- Edges to services -->
    <mxCell id="es1" style="rounded=1;dashed=1;strokeColor=#82b366;" edge="1" source="app1" target="milvus" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="es2" style="rounded=1;dashed=1;strokeColor=#b85450;" edge="1" source="app2" target="redis" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="es3" style="rounded=1;dashed=1;strokeColor=#d6b656;" edge="1" source="app3" target="oss" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="es4" style="rounded=1;dashed=1;strokeColor=#9673a6;" edge="1" source="app3" target="llmapi" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Also from app1/app2 to milvus/redis -->
    <mxCell id="es5" style="rounded=1;dashed=1;strokeColor=#82b366;opacity=50;" edge="1" source="app2" target="milvus" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="es6" style="rounded=1;dashed=1;strokeColor=#9673a6;opacity=50;" edge="1" source="app1" target="llmapi" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Monitoring -->
    <mxCell id="mon" value="监控层" style="swimlane;startSize=20;fillColor=#f5f5f5;strokeColor=#CCCCCC;rounded=1;fontSize=10;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="355" width="580" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="prom" value="Prometheus&#xa;+ Grafana" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=9;" vertex="1" parent="mon">
      <mxGeometry x="20" y="25" width="100" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="log" value="ELK / Loki&#xa;(日志)" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=9;" vertex="1" parent="mon">
      <mxGeometry x="160" y="25" width="90" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="alert" value="告警规则&#xa;(检索慢/LLM延迟)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="mon">
      <mxGeometry x="290" y="25" width="140" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="dash" value="Dashboard&#xa;(面板)" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=9;" vertex="1" parent="mon">
      <mxGeometry x="470" y="25" width="90" height="25" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
