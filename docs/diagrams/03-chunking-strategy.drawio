<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="递归分块 + 重叠示意图" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="170" y="20" width="300" height="30" as="geometry"/>
    </mxCell>
    <!-- Original Doc -->
    <mxCell id="orig" value="原始文档（1200字）&#xa;第一章 总则 | 第一条 | 第二条 | 第三条 | ..." style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="70" width="480" height="50" as="geometry"/>
    </mxCell>
    <!-- Arrow -->
    <mxCell id="ea" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="orig" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="320" y="160" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="eal" value="递归分块&#xa;chunk_size=300&#xa;overlap=60" style="text;fontSize=10;fontColor=#666666;align=center;" vertex="1" parent="1">
      <mxGeometry x="560" y="85" width="100" height="40" as="geometry"/>
    </mxCell>
    <!-- Chunk 1 -->
    <mxCell id="c1" value="块 1（300字）&#xa;第一章 总则&#xa;第一条 为了加强国土空间规划管理..." style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
      <mxGeometry x="80" y="170" width="300" height="50" as="geometry"/>
    </mxCell>
    <!-- Overlap 1 -->
    <mxCell id="o1" value="重叠区&#xa;（60字）" style="rounded=0;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="320" y="170" width="60" height="50" as="geometry"/>
    </mxCell>
    <!-- Chunk 2 -->
    <mxCell id="c2" value="块 2（300字）&#xa;...规划管理，优化国土空间布局&#xa;第二条 国土空间规划包括总体规划..." style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
      <mxGeometry x="140" y="260" width="300" height="50" as="geometry"/>
    </mxCell>
    <!-- Overlap 2 -->
    <mxCell id="o2" value="重叠区&#xa;（60字）" style="rounded=0;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="380" y="260" width="60" height="50" as="geometry"/>
    </mxCell>
    <!-- Chunk 3 -->
    <mxCell id="c3" value="块 3（300字）&#xa;...总体规划、详细规划和相关专项规划&#xa;第三条 国土空间规划的编制应当..." style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
      <mxGeometry x="200" y="350" width="300" height="50" as="geometry"/>
    </mxCell>
    <!-- Arrows between chunks -->
    <mxCell id="ec1" style="rounded=1;dashed=1;strokeColor=#d6b656;" edge="1" source="c1" target="c2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="ec2" style="rounded=1;dashed=1;strokeColor=#d6b656;" edge="1" source="c2" target="c3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Note -->
    <mxCell id="note" value="关键设计：重叠区域确保&#xa;跨块信息不丢失" style="text;fontSize=11;fontStyle=2;fontColor=#82b366;align=center;" vertex="1" parent="1">
      <mxGeometry x="160" y="430" width="200" height="30" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
