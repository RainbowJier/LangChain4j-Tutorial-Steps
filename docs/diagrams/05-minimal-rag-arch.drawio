<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="最小 RAG 架构总览" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="180" y="15" width="300" height="30" as="geometry"/>
    </mxCell>
    <!-- Phase 1: Offline Ingestion -->
    <mxCell id="phase1" value="离线阶段：文档摄入" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="580" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="doc" value="文档&#xa;PDF/DOCX/TXT" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="phase1">
      <mxGeometry x="20" y="35" width="90" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="parse" value="解析" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="phase1">
      <mxGeometry x="140" y="35" width="70" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="split" value="分块&#xa;(500字/块)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="phase1">
      <mxGeometry x="240" y="35" width="80" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="embed" value="向量化&#xa;(Embedding)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="phase1">
      <mxGeometry x="350" y="35" width="80" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="save" value="向量存储" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="phase1">
      <mxGeometry x="465" y="30" width="80" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="f1e1" style="rounded=1;" edge="1" source="doc" target="parse" parent="phase1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f1e2" style="rounded=1;" edge="1" source="parse" target="split" parent="phase1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f1e3" style="rounded=1;" edge="1" source="split" target="embed" parent="phase1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f1e4" style="rounded=1;" edge="1" source="embed" target="save" parent="phase1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Phase 2: Online Query -->
    <mxCell id="phase2" value="在线阶段：检索生成" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="190" width="580" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="query" value="用户问题" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="phase2">
      <mxGeometry x="20" y="35" width="80" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="qembed" value="问题&#xa;向量化" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="phase2">
      <mxGeometry x="130" y="35" width="70" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="retrieve" value="检索&#xa;(Top-5)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="phase2">
      <mxGeometry x="230" y="35" width="70" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="prompt" value="拼接&#xa;Prompt" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="phase2">
      <mxGeometry x="330" y="35" width="70" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="llm" value="LLM&#xa;生成" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="phase2">
      <mxGeometry x="430" y="35" width="70" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="answer" value="回答" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="phase2">
      <mxGeometry x="530" y="35" width="40" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="f2e1" style="rounded=1;" edge="1" source="query" target="qembed" parent="phase2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f2e2" style="rounded=1;" edge="1" source="qembed" target="retrieve" parent="phase2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f2e3" style="rounded=1;" edge="1" source="retrieve" target="prompt" parent="phase2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f2e4" style="rounded=1;" edge="1" source="prompt" target="llm" parent="phase2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="f2e5" style="rounded=1;" edge="1" source="llm" target="answer" parent="phase2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Store reference -->
    <mxCell id="storeRef" value="向量存储" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="640" y="210" width="70" height="45" as="geometry"/>
    </mxCell>
    <mxCell id="refEdge" style="dashed=1;strokeColor=#82b366;curved=1;" edge="1" source="retrieve" target="storeRef" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- LangChain4j Components -->
    <mxCell id="comp" value="LangChain4j 组件对应：" style="text;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="40" y="310" width="180" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="comp1" value="EmbeddingStoreIngestor" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="40" y="335" width="150" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="comp2" value="ContentRetriever" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="210" y="335" width="120" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="comp3" value="AiServices" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="350" y="335" width="90" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="comp4" value="ChatModel" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="460" y="335" width="80" height="25" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
