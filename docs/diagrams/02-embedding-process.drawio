<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="title" value="文本向量化全过程" style="text;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="220" y="20" width="260" height="30" as="geometry"/>
    </mxCell>
    <!-- Input Text -->
    <mxCell id="input" value="输入文本：&#xa;&quot;生态保护红线范围内&#xa;禁止开发建设活动&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="1">
      <mxGeometry x="250" y="70" width="200" height="60" as="geometry"/>
    </mxCell>
    <!-- Tokenization -->
    <mxCell id="token" value="分词 / Tokenization&#xa;[&quot;生态&quot;, &quot;保护&quot;, &quot;红线&quot;, ...]" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="250" y="170" width="200" height="50" as="geometry"/>
    </mxCell>
    <!-- Embedding Model -->
    <mxCell id="model" value="Embedding 模型&#xa;(AllMiniLmL6V2 神经网络)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="250" y="260" width="200" height="50" as="geometry"/>
    </mxCell>
    <!-- Vector Output -->
    <mxCell id="vector" value="输出向量 (384维)：&#xa;[0.82, -0.15, 0.33, ..., -0.12]" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="250" y="350" width="200" height="50" as="geometry"/>
    </mxCell>
    <!-- Vector DB -->
    <mxCell id="db" value="向量数据库" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="280" y="440" width="140" height="60" as="geometry"/>
    </mxCell>
    <!-- Edges -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="input" target="token" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="token" target="model" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="model" target="vector" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="vector" target="db" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Side annotations -->
    <mxCell id="a1" value="模型内部&#xa;（黑盒）" style="text;fontSize=10;fontColor=#999999;align=left;" vertex="1" parent="1">
      <mxGeometry x="470" y="250" width="80" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="a2" value="语义空间&#xa;中的坐标" style="text;fontSize=10;fontColor=#999999;align=left;" vertex="1" parent="1">
      <mxGeometry x="470" y="345" width="80" height="30" as="geometry"/>
    </mxCell>
    <!-- Dimension labels -->
    <mxCell id="dim" value="384个数字 = 384个语义特征的组合" style="text;fontSize=10;fontColor=#82b366;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="80" y="350" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="dimline" style="dashed=1;strokeColor=#82b366;" edge="1" source="dim" target="vector" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
